---
import { getCollection } from "astro:content";
import Nav from "../components/Nav.astro";

const memos = await getCollection("memos");

// newest first
memos.sort((a,b)=> a.data.published_at < b.data.published_at ? 1 : -1);

const latest = memos[0];
const recent = memos.slice(1,6);
---

<html lang="en">

<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>The Journal of Revised Truth</title>

<style>

body{
  margin:0;
  font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial;
  background:#fff;
  color:#111;
}

main{
  max-width:980px;
  margin:0 auto;
  padding:56px 20px;
}

h1{
  font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
  font-weight:600;
  margin-bottom:12px;
}

.intro{
  max-width:760px;
  line-height:1.7;
}

.section{
  margin-top:42px;
}

.memo{
  margin-top:18px;
  padding-top:12px;
  border-top:1px solid #e5e5e5;
}

.memo-title{
  font-size:18px;
}

.meta{
  font-size:13px;
  color:#555;
}

a{
  color:inherit;
  text-decoration: underline;
  text-decoration-thickness:1px;
  text-underline-offset:3px;
}

</style>

</head>

<body>

<main>

<h1>The Journal of Revised Truth</h1>

<div class="intro">

<p>
The Journal compiles memoranda concerning the revision of previously settled
understandings across eras, institutions, and domains.
</p>

<p>
Documents are presented with their known circulation stage and archival status.
Provenance may be incomplete. Interpretations remain subject to clarification.
</p>

<p>
Humanity remains operational.
</p>
<hr style="border:none;border-top:1px solid #e5e5e5;margin:26px 0;" />

</div>

<Nav />

<div class="section">

<h2>Latest Memorandum</h2>

{latest && (

<div class="memo">

<div class="meta">
{latest.data.division} · {latest.data.memo_id} · {latest.data.published_at}
</div>

<div class="memo-title">
<a href={`/memos/${latest.slug}`}>
{latest.data.title}
</a>
</div>

</div>

)}

</div>


<div class="section">

<h2>Recent Memoranda</h2>

{recent.map(m => (

<div class="memo">

<div class="meta">
{m.data.division} · {m.data.memo_id} · {m.data.published_at}
</div>

<div class="memo-title">
<a href={`/memos/${m.slug}`}>
{m.data.title}
</a>
</div>

</div>

))}

</div>


</main>

</body>

</html>