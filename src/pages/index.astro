---
import { getCollection } from "astro:content";
import Layout from "../layouts/JournalLayout.astro";

const memos = await getCollection("memos");
memos.sort((a, b) => (a.data.published_at < b.data.published_at ? 1 : -1));

const latest = memos[0];
const recent = memos.slice(1, 6);
---

<Layout title="Home" current="home">

  <h1>Current Filings</h1>

  <div style="font-size:13px; color:#666; margin-bottom:16px;">
    Volume I · Issue 1 · Provisional Circulation
  </div>

  <div style="font-size:13px; color:#666; margin-bottom:24px;">
    Total Records: {memos.length} · Classification: Declassified
  </div>

  <p style="max-width:760px; line-height:1.7;">
    The Journal compiles memoranda concerning the revision of previously settled
    understandings across historical eras, institutional frameworks, and operational
    domains.
  </p>

  <p style="max-width:760px; line-height:1.7;">
    Documents are presented according to their known circulation stage and archival
    status. Origin may be incomplete. Interpretations remain subject to clarification
    pending further review.
  </p>

  <div style="margin-top:42px;">
    <h2 style="font-family: ui-serif, Georgia, Cambria, 'Times New Roman', Times, serif; font-weight:600; margin-bottom:12px;">
      Most Recent Filing
    </h2>

    {latest && (
      <article style="margin-top:18px; padding-top:12px; border-top:1px solid #e5e5e5; max-width:780px;">
        <div style="font-size:13px; color:#555;">
          {latest.data.document_id} · {latest.data.division} · {latest.data.status} · {latest.data.published_at}
        </div>

        <div style="font-size:18px; margin-top:6px;">
          <a href={`/memos/${latest.slug}`}>{latest.data.title}</a>
        </div>

        <div style="font-size:13px; color:#666; margin-top:6px;">
          Series: {latest.data.series}
        </div>
      </article>
    )}
  </div>

  <div style="margin-top:42px;">
    <h2 style="font-family: ui-serif, Georgia, Cambria, 'Times New Roman', Times, serif; font-weight:600; margin-bottom:12px;">
      Archival Records
    </h2>

    {recent.map((m) => (
      <article style="margin-top:18px; padding-top:12px; border-top:1px solid #e5e5e5; max-width:780px;">
        <div style="font-size:13px; color:#555;">
          {m.data.document_id} · {m.data.division} · {m.data.status} · {m.data.published_at}
        </div>

        <div style="font-size:18px; margin-top:6px;">
          <a href={`/memos/${m.slug}`}>{m.data.title}</a>
        </div>

        <div style="font-size:13px; color:#666; margin-top:6px;">
          Series: {m.data.series}
        </div>
      </article>
    ))}
  </div>

</Layout>