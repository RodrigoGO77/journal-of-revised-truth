---
import { getCollection } from "astro:content";
import Layout from "../layouts/JournalLayout.astro";

const memos = await getCollection("memos");
memos.sort((a, b) => (a.data.published_at < b.data.published_at ? 1 : -1));

const latest = memos[0];
const recent = memos.slice(1, 6);
---

<Layout title="Home" current="home">

  <h1>Current Filings</h1>

  <p style="max-width:760px; line-height:1.7;">
    The Journal compiles memoranda concerning the revision of previously settled
    understandings across eras, institutions, and domains.
  </p>

  <p style="max-width:760px; line-height:1.7;">
    Documents are presented with their known circulation stage and archival status.
    Origin may be incomplete. Interpretations remain subject to clarification.
  </p>

  <div style="margin-top:42px;">
    <h2 style="font-family: ui-serif, Georgia, Cambria, 'Times New Roman', Times, serif; font-weight:600; margin-bottom:12px;">
      Latest Memorandum
    </h2>

    {latest && (
      <div style="margin-top:18px; padding-top:12px; border-top:1px solid #e5e5e5;">
        <div style="font-size:13px; color:#555;">
          {latest.data.division} · {latest.data.memo_id} · {latest.data.published_at}
        </div>

        <div style="font-size:18px; margin-top:6px;">
          <a href={`/memos/${latest.slug}`}>{latest.data.title}</a>
        </div>
      </div>
    )}
  </div>

  <div style="margin-top:42px;">
    <h2 style="font-family: ui-serif, Georgia, Cambria, 'Times New Roman', Times, serif; font-weight:600; margin-bottom:12px;">
      Earlier Filings
    </h2>

    {recent.map((m) => (
      <div style="margin-top:18px; padding-top:12px; border-top:1px solid #e5e5e5; max-width:780px;">
        <div style="font-size:13px; color:#555;">
          {m.data.division} · {m.data.memo_id} · {m.data.published_at}
        </div>

        <div style="font-size:18px; margin-top:6px;">
          <a href={`/memos/${m.slug}`}>{m.data.title}</a>
        </div>
      </div>
    ))}
  </div>

</Layout>