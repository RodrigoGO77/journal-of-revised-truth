---
import { getCollection } from "astro:content";
import { buildMemoIndex } from "../../lib/memoIndex";
import Nav from "../../components/Nav.astro";
import "../../styles/journal.css";

export async function getStaticPaths() {
  const memos = await getCollection("memos");
  return memos.map((m) => ({ params: { slug: m.slug }, props: { memo: m } }));
}

const { memo } = Astro.props;
const { Content } = await memo.render();

const memoIndex = await buildMemoIndex();
const allMemos = await getCollection("memos");

const thisId = memo.data.document_id ?? memo.data.memo_id;

const inbound = allMemos
  .filter(
    (m) =>
      m.data.amends === thisId ||
      m.data.retracts === thisId ||
      m.data.superseded_by === thisId
  )
  .sort((a, b) => (a.data.published_at < b.data.published_at ? 1 : -1));

function relationLabel(m) {
  if (m.data.amends === thisId) return "Amends this memorandum";
  if (m.data.retracts === thisId) return "Retracts this memorandum";
  if (m.data.superseded_by === thisId) return "Supersedes this memorandum";
  return "References this memorandum";
}

function linkFor(id) {
  if (!id) return null;
  return memoIndex[id] ?? null;
}

const referencedMemos = (memo.data.references ?? [])
  .map((id) => {
    const match = allMemos.find(
      (m) => (m.data.document_id ?? m.data.memo_id) === id
    );
    return match
      ? {
          id,
          title: match.data.title,
          slug: match.slug,
          published_at: match.data.published_at,
        }
      : null;
  })
  .filter(Boolean);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{memo.data.title} — The Journal of Revised Truths</title>
    <meta
      name="description"
      content={`${memo.data.title} — memorandum from the Journal of Revised Truths.`}
    />
    <meta property="og:title" content={memo.data.title} />
    <meta
      property="og:description"
      content="Memorandum from the Journal of Revised Truths archive."
    />
    <meta property="og:type" content="article" />
    <meta
      property="og:url"
      content={`https://journalofrevisedtruth.netlify.app/memos/${memo.slug}`}
    />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={memo.data.title} />
    <meta
      name="twitter:description"
      content="Memorandum from the Journal of Revised Truths archive."
    />

    <style>
      .archival-note {
        font-size: 14px;
        line-height: 1.6;
        color: #333;
      }
    </style>
  </head>

  <body>
    <main>
      <div class="masthead">
        <div class="site-title">The Journal of Revised Truths</div>
        <div class="motto">Humanity remains operational.</div>
      </div>

      <Nav current="archive" />

      <hr />

      <div class="memo-shell">
        <h1 class="memo-title">{memo.data.title}</h1>

        <div class="document-header">
          <div class="document-header-grid">
            <div class="document-header-meta">
              <div>
                <strong>Document ID:</strong> {memo.data.document_id ?? memo.data.memo_id}
              </div>

              {memo.data.document_id ? (
                <div>
                  <strong>Reference:</strong> {memo.data.memo_id}
                </div>
              ) : null}

              <div>
                <strong>Division:</strong> {memo.data.division}
              </div>

              {memo.data.series ? (
                <div>
                  <strong>Series:</strong>{" "}
                  {memo.data.series_slug ? (
                    <a href={`/series/${memo.data.series_slug}`}>{memo.data.series}</a>
                  ) : (
                    memo.data.series
                  )}
                </div>
              ) : null}

              <div>
                <strong>Stage:</strong> {memo.data.stage}
              </div>

              <div>
                <strong>Status:</strong> {memo.data.status}
              </div>

              {memo.data.provenance ? (
                <div>
                  <strong>Provenance:</strong> {memo.data.provenance}
                </div>
              ) : null}

              <div>
                <strong>Filed:</strong> {memo.data.published_at}
              </div>

              {memo.data.amends ? (
                <div>
                  <strong>Amends:</strong>{" "}
                  {linkFor(memo.data.amends) ? (
                    <a href={linkFor(memo.data.amends)}>{memo.data.amends}</a>
                  ) : (
                    <span>{memo.data.amends}</span>
                  )}
                </div>
              ) : null}

              {memo.data.retracts ? (
                <div>
                  <strong>Retracts:</strong>{" "}
                  {linkFor(memo.data.retracts) ? (
                    <a href={linkFor(memo.data.retracts)}>{memo.data.retracts}</a>
                  ) : (
                    <span>{memo.data.retracts}</span>
                  )}
                </div>
              ) : null}

              {memo.data.superseded_by ? (
                <div>
                  <strong>Superseded by:</strong>{" "}
                  {linkFor(memo.data.superseded_by) ? (
                    <a href={linkFor(memo.data.superseded_by)}>{memo.data.superseded_by}</a>
                  ) : (
                    <span>{memo.data.superseded_by}</span>
                  )}
                </div>
              ) : null}
            </div>

            <div class="document-header-stamp">
              {memo.data.stamp && (
                <div class="declassified-stamp">{memo.data.stamp}</div>
              )}
            </div>
          </div>
        </div>

        <article data-memo={memo.data.memo_id ?? memo.data.document_id}>
          <Content />
        </article>
      </div>

      {referencedMemos.length ? (
        <>
          <hr />
          <div class="meta">
            <div><strong>Cross-referenced memoranda</strong></div>
            <ul style="margin:10px 0 0; padding-left:18px;">
              {referencedMemos.map((m) => (
                <li style="margin:6px 0;">
                  <a href={`/memos/${m.slug}`}>{m.id}</a>
                  {" — "}
                  {m.published_at}
                  {" · "}
                  {m.title}
                </li>
              ))}
            </ul>
          </div>
        </>
      ) : null}

      {inbound.length ? (
        <>
          <hr />
          <div class="meta">
            <div><strong>Related memoranda</strong></div>
            <ul style="margin:10px 0 0; padding-left:18px;">
              {inbound.map((m) => (
                <li style="margin:6px 0;">
                  <a href={`/memos/${m.slug}`}>{m.data.document_id ?? m.data.memo_id}</a>
                  {" — "}
                  {relationLabel(m)}
                  {" · "}
                  {m.data.published_at}
                  {" · "}
                  {m.data.title}
                </li>
              ))}
            </ul>
          </div>
        </>
      ) : null}

      <hr />

      <div class="archival-note">
        <strong>ARCHIVAL NOTE</strong><br /><br />
        {memo.data.series ? (
          <>
            This memorandum forms part of the <strong>{memo.data.series}</strong> series.<br /><br />
          </>
        ) : (
          <>
            This memorandum is filed within the current archival series structure.<br /><br />
          </>
        )}
        Catalog classification and sequencing reflect current archival practice and may not correspond to original circulation order.<br /><br />
        Some related materials remain unavailable.
      </div>

      <hr />

      <Nav />
    </main>
  </body>
</html>