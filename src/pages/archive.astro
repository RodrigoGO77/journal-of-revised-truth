---
import { getCollection } from "astro:content";
import Layout from "../layouts/JournalLayout.astro";

const memos = await getCollection("memos");

memos.sort((a, b) =>
  a.data.published_at < b.data.published_at ? 1 : -1
);
---

<Layout title="Archive" current="archive">

<h1>Archive</h1>

<div style="font-size:13px; color:#666; margin-bottom:28px;">
Archival Record Index · Total Records: {memos.length}
</div>

{memos.map((m) => (

  <div style="margin-bottom:18px; padding-bottom:12px; border-bottom:1px solid #e5e5e5; max-width:780px;">

    <div style="font-size:15px;">
      <a href={`/memos/${m.slug}`}>
        <strong>{m.data.document_id ?? m.data.memo_id}</strong>
      </a>
      {" — "}
      {m.data.title}
    </div>

    <div style="font-size:13px; color:#555; margin-top:4px;">
      {m.data.division} · {m.data.published_at}
    </div>

  </div>

))}

</Layout>