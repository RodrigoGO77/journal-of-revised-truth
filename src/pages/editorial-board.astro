---
import Nav from "../components/Nav.astro";
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Editorial Board — The Journal of Revised Truth</title>
  <style>
    body{margin:0;font-family:ui-sans-serif,system-ui;background:#fff;color:#111}
    main{max-width:780px;margin:0 auto;padding:56px 20px}
    h1{font-family:ui-serif,Georgia,serif;font-weight:600;margin:0 0 18px}
    p{font-size:18px;line-height:1.7;margin:0 0 16px}
    nav{margin-top:18px;font-size:14px;display:flex;gap:18px;flex-wrap:wrap}
    a{color:inherit;text-decoration:underline;text-underline-offset:3px}
    .note{font-size:14px;color:#333;margin-top:20px}
  </style>
</head>
<body>
<main>
  <h1>Editorial Board</h1>

  <p>The Editorial Office is responsible for collation, minimal formatting, and publication of materials currently available to the archive.</p>
  <p>Where signatures are missing, names are withheld. Where certainty is unavailable, uncertainty is preserved.</p>

  <div class="note">Correspondence may be addressed to the Editorial Office. Responses are not guaranteed.</div>
  <hr style="border:none;border-top:1px solid #e5e5e5;margin:26px 0;" />

  <nav>
    <Nav current="editorial-board" />
  </nav>
  
</main>
</body>
</html>