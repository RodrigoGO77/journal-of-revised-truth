---
import { getCollection } from "astro:content";
import Layout from "../../layouts/JournalLayout.astro";

export async function getStaticPaths() {
  const memos = await getCollection("memos");

  const slugs = Array.from(
    new Set(
      memos
        .map((m) => m.data.series_slug)
        .filter((s) => typeof s === "string" && s.length > 0)
    )
  );

  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

const memos = await getCollection("memos");
const list = memos
  .filter((m) => m.data.series_slug === slug)
  .sort((a, b) => (a.data.published_at < b.data.published_at ? 1 : -1));

const seriesName = list[0]?.data.series ?? "Series";
---

<Layout title={seriesName} current="series">

  <h1>{seriesName}</h1>

  <p style="max-width:780px; line-height:1.6; color:#333;">
    Documents are organized into thematic series. Classification reflects current
    archival practice and remains subject to revision.
  </p>

  {list.length ? (
    <div style="margin-top:26px; max-width:780px; border-top:1px solid #e5e5e5;">
      {list.map((m) => (
        <div style="padding:16px 0; border-bottom:1px solid #e5e5e5;">
          <div style="font-size:13px; color:#333; line-height:1.6;">
            Filed: {m.data.published_at} · Memorandum {m.data.memo_id} · {m.data.division}
          </div>

          <div style="font-size:18px; margin-top:6px;">
            <a href={`/memos/${m.slug}`}>{m.data.title}</a>
          </div>
        </div>
      ))}
    </div>
  ) : (
    <div style="margin-top:26px; color:#333; font-size:14px;">
      No memoranda currently filed under this series slug: <strong>{slug}</strong>.
    </div>
  )}

</Layout>