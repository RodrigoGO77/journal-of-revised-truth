---
import { getCollection } from "astro:content";
import Nav from "../../components/Nav.astro";

export async function getStaticPaths() {
  const memos = await getCollection("memos");

  const slugs = Array.from(
    new Set(
      memos
        .map((m) => m.data.series_slug)
        .filter((s) => typeof s === "string" && s.length > 0)
    )
  );

  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

const memos = await getCollection("memos");
const list = memos
  .filter((m) => m.data.series_slug === slug)
  .sort((a, b) => (a.data.published_at < b.data.published_at ? 1 : -1));

const seriesName = list[0]?.data.series ?? "Series";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{seriesName} — The Journal of Revised Truth</title>
    <style>
      body { margin: 0; font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial; background:#fff; color:#111; }
      main { max-width: 980px; margin: 0 auto; padding: 56px 20px; }
      h1 { font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif; font-weight: 600; margin: 0 0 10px; }
      .sub { max-width: 780px; font-size: 16px; line-height: 1.6; color:#333; }
      a { color: inherit; text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px; }
      .list { margin-top: 26px; max-width: 780px; border-top: 1px solid #e5e5e5; }
      .row { padding: 16px 0; border-bottom: 1px solid #e5e5e5; }
      .meta { font-size: 13px; color:#333; line-height:1.6; }
      .title { font-size: 18px; margin-top: 6px; }
      .empty { margin-top: 26px; color:#333; font-size: 14px; }
      hr { border: none; border-top: 1px solid #e5e5e5; margin: 26px 0; }
    </style>
  </head>

  <body>
    <main>
      <h1>{seriesName}</h1>
      <div class="sub">
        Documents are organized into thematic series. Classification reflects current archival practice and remains subject to revision.
      </div>

      <Nav current="series" />

      {list.length ? (
        <div class="list">
          {list.map((m) => (
            <div class="row">
              <div class="meta">
                Filed: {m.data.published_at} · Memorandum {m.data.memo_id} · {m.data.division}
              </div>
              <div class="title">
                <a href={`/memos/${m.slug}`}>{m.data.title}</a>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="empty">
          No memoranda currently filed under this series slug: <strong>{slug}</strong>.
        </div>
      )}
    </main>
  </body>
</html>