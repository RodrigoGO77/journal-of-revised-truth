---
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const memos = await getCollection("memos");
  const slugs = Array.from(new Set(memos.map(m => m.data.series_slug).filter(Boolean)));
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

const memos = await getCollection("memos");
const list = memos
  .filter((m) => m.data.series_slug === slug)
  .sort((a,b)=> (a.data.published_at < b.data.published_at ? 1 : -1));

const seriesName = list[0]?.data.series ?? "Series";
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{seriesName} — The Journal of Revised Truth</title>
  <style>
    body{margin:0;font-family:ui-sans-serif,system-ui;background:#fff;color:#111}
    main{max-width:980px;margin:0 auto;padding:56px 20px}
    h1{font-family:ui-serif,Georgia,serif;font-weight:600;margin:0 0 10px}
    .sub{max-width:780px;font-size:16px;line-height:1.6;color:#333}
    nav{margin-top:18px;font-size:14px;display:flex;gap:18px;flex-wrap:wrap}
    a{color:inherit;text-decoration:underline;text-underline-offset:3px}
    .list{margin-top:26px;max-width:780px;border-top:1px solid #e5e5e5}
    .row{padding:16px 0;border-bottom:1px solid #e5e5e5}
    .meta{font-size:13px;color:#333;line-height:1.6}
    .title{font-size:18px;margin-top:6px}
  </style>
</head>
<body>
<main>
  <h1>{seriesName}</h1>
  <div class="sub">Memoranda filed under this series are listed by filing date.</div>

  <nav>
    <a href="/">Home</a>
    <a href="/archive">Archive</a>
    <a href="/series">Series</a>
  </nav>

  <div class="list">
    {list.map((m) => (
      <div class="row">
        <div class="meta">{m.data.division} · Memorandum {m.data.memo_id} · {m.data.published_at}</div>
        <div class="title"><a href={`/memos/${m.slug}`}>{m.data.title}</a></div>
      </div>
    ))}
  </div>
</main>
</body>
</html>