---
import { getCollection } from "astro:content";
import Layout from "../../layouts/JournalLayout.astro";

const memos = await getCollection("memos");

const seriesMap = {};

for (const m of memos) {
  const key = m.data.series_slug;
  if (!key) continue;

  if (!seriesMap[key]) {
    seriesMap[key] = {
      name: m.data.series,
      slug: m.data.series_slug,
      count: 0,
      latest: m.data.published_at
    };
  }

  seriesMap[key].count++;

  if (m.data.published_at > seriesMap[key].latest) {
    seriesMap[key].latest = m.data.published_at;
  }
}

const series = Object.values(seriesMap).sort((a, b) =>
  a.name.localeCompare(b.name)
);
---

<Layout title="Series" current="series">

  <h1>Series</h1>

  <p style="max-width:720px; line-height:1.7; color:#333;">
    Documents are organized into thematic series reflecting the ongoing revision of
    institutional, scientific, and civilizational understandings.
  </p>

  <div style="margin-top:26px; border-top:1px solid #e5e5e5; max-width:780px;">
    {series.map((s) => (
      <div style="padding:18px 0; border-bottom:1px solid #e5e5e5;">
        <div style="font-size:18px;">
          <a href={`/series/${s.slug}`}>{s.name}</a>
        </div>

        <div style="font-size:13px; color:#555; line-height:1.6; margin-top:6px;">
          {s.count} memoranda · Latest filing: {s.latest}
        </div>
      </div>
    ))}
  </div>

</Layout>