import Layout from "../layouts/JournalLayout.astro";
---

<Layout title="About" current="about">

  <h1>About</h1>

  <p style="max-width:760px; line-height:1.7;">
    The <strong>Journal of Revised Truth</strong> compiles memoranda concerning the evolution of
    human understanding across eras, institutions, and domains.
  </p>

  <p style="max-width:760px; line-height:1.7;">
    Documents are reproduced in their archival form when available and include
    the circulation stage and administrative status recorded at the time of
    filing. Provenance may be incomplete, and certain materials remain partially
    redacted.
  </p>

  <p style="max-width:760px; line-height:1.7;">
    The Journal does not issue final determinations regarding historical events.
    Its function is primarily documentary. Interpretations remain subject to
    clarification.
  </p>

  <p style="max-width:760px; line-height:1.7;">
    <strong>History remains pending administrative confirmation.</strong>
  </p>

  <p style="max-width:760px; line-height:1.7;">
    Earlier related memoranda remain partially unrecovered. Catalog sequencing
    reflects current archival practice and may not correspond to original
    circulation order.
  </p>

</Layout>