---
import { getCollection } from "astro:content";
import Layout from "../../layouts/JournalLayout.astro";

export async function getStaticPaths() {
  const memos = await getCollection("memos");
  const slugs = Array.from(new Set(memos.map((m) => m.data.division_slug)));

  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

const memos = await getCollection("memos");

const list = memos
  .filter((m) => m.data.division_slug === slug)
  .sort((a, b) => (a.data.published_at < b.data.published_at ? 1 : -1));

const divisionName = list[0]?.data.division ?? "Division";
---

<Layout title={divisionName} current="divisions">

  <h1>{divisionName}</h1>

  <p style="max-width:780px; line-height:1.6; color:#333;">
    Divisional organization reflects current archival practice and remains subject to revision.
  </p>

  <div style="margin-top:26px; border-top:1px solid #e5e5e5; max-width:780px;">
    {list.map((m) => (
      <div style="padding:16px 0; border-bottom:1px solid #e5e5e5;">
        <div style="font-size:13px; color:#333; line-height:1.6;">
          Memorandum {m.data.memo_id} · {m.data.published_at}
          {m.data.series_slug ? (
            <span>
              {" · Series: "}
              <a href={`/series/${m.data.series_slug}`}>{m.data.series}</a>
            </span>
          ) : null}
        </div>

        <div style="font-size:18px; margin-top:6px;">
          <a href={`/memos/${m.slug}`}>{m.data.title}</a>
        </div>
      </div>
    ))}
  </div>

</Layout>