---
import { getCollection } from "astro:content";
import Nav from "../../components/Nav.astro";

export async function getStaticPaths() {
  const memos = await getCollection("memos");
  const slugs = Array.from(new Set(memos.map((m) => m.data.division_slug)));

  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

const memos = await getCollection("memos");

const list = memos
  .filter((m) => m.data.division_slug === slug)
  .sort((a, b) => (a.data.published_at < b.data.published_at ? 1 : -1));

const divisionName = list[0]?.data.division ?? "Division";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{divisionName} — The Journal of Revised Truth</title>

    <style>
      body {
        margin: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial;
        background: #fff;
        color: #111;
      }

      main {
        max-width: 980px;
        margin: 0 auto;
        padding: 56px 20px;
      }

      h1 {
        font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
        font-weight: 600;
        margin: 0 0 10px;
      }

      .sub {
        max-width: 780px;
        font-size: 16px;
        line-height: 1.6;
        color: #333;
      }

      .list {
        margin-top: 26px;
        border-top: 1px solid #e5e5e5;
        max-width: 780px;
      }

      .row {
        padding: 16px 0;
        border-bottom: 1px solid #e5e5e5;
      }

      .meta {
        font-size: 13px;
        color: #333;
        line-height: 1.6;
      }

      .title {
        font-size: 18px;
        margin-top: 6px;
      }

      a {
        color: inherit;
        text-decoration: underline;
        text-underline-offset: 3px;
      }
    </style>
  </head>

  <body>
    <main>
      <h1>{divisionName}</h1>

      <div class="sub">
        Divisional organization reflects current archival practice and remains subject to revision.
      </div>

      <Nav current="divisions" />

      <div class="list">
        {list.map((m) => (
          <div class="row">
            <div class="meta">
              Memorandum {m.data.memo_id} · {m.data.published_at}
              {m.data.series_slug ? (
                <span>
                  {" · Series: "}
                  <a href={`/series/${m.data.series_slug}`}>{m.data.series}</a>
                </span>
              ) : null}
            </div>

            <div class="title">
              <a href={`/memos/${m.slug}`}>
                {m.data.title}
              </a>
            </div>
          </div>
        ))}
      </div>
    </main>
  </body>
</html>