---
import { getCollection } from "astro:content";

const memos = await getCollection("memos");

// division_slug -> { name, memos }
const byDivision = new Map<string, { name: string; memos: typeof memos }>();

for (const m of memos) {
  const slug = m.data.division_slug;
  if (!byDivision.has(slug)) byDivision.set(slug, { name: m.data.division, memos: [] });
  byDivision.get(slug)!.memos.push(m);
}

// sort divisions by name
const divisions = Array.from(byDivision.entries()).sort((a, b) => a[1].name.localeCompare(b[1].name));

// newest memo first for each division
for (const [, obj] of byDivision.entries()) {
  obj.memos.sort((a, b) => (a.data.published_at < b.data.published_at ? 1 : -1));
}
