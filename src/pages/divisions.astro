---
import { getCollection } from "astro:content";
import Layout from "../layouts/JournalLayout.astro";

const memos = await getCollection("memos");

/* build division map */

const divisions = {};

for (const m of memos) {
  const d = m.data.division;

  if (!divisions[d]) {
    divisions[d] = {
      slug: m.data.division_slug,
      latest: m.data.published_at,
    };
  } else {
    if (m.data.published_at > divisions[d].latest) {
      divisions[d].latest = m.data.published_at;
    }
  }
}

const list = Object.entries(divisions).sort(
  (a, b) => b[1].latest.localeCompare(a[1].latest)
);
---

<Layout title="Divisions" current="divisions">

<h1>Divisions</h1>

<p>
Divisional organization reflects current archival practice and remains subject to revision.
</p>

<div style="margin-top:26px;border-top:1px solid #e5e5e5;max-width:780px;">

{list.map(([name, data]) => (

  <div style="padding:16px 0;border-bottom:1px solid #e5e5e5;">

    <div style="font-size:18px;">
      <a href={`/divisions/${data.slug}`}>
        {name}
      </a>
    </div>

    <div style="font-size:13px;color:#333;margin-top:4px;">
      Latest filing: {data.latest}
    </div>

  </div>

))}

</div>

</Layout>