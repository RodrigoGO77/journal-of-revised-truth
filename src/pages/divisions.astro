---
import { getCollection } from "astro:content";
import Nav from "../components/Nav.astro";

const memos = await getCollection("memos");

// Collect unique divisions by division_slug
const divisionMap = {};

for (const m of memos) {
  const slug = m.data.division_slug;
  if (!slug) continue;

  if (!divisionMap[slug]) {
    divisionMap[slug] = {
      name: m.data.division,
      slug: m.data.division_slug,
      latest: m.data.published_at
    };
  } else {
    if (m.data.published_at > divisionMap[slug].latest) {
      divisionMap[slug].latest = m.data.published_at;
    }
  }
}

const divisions = Object.values(divisionMap).sort((a, b) =>
  a.name.localeCompare(b.name)
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Divisions — The Journal of Revised Truth</title>
    <style>
      body { margin: 0; font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial; background:#fff; color:#111; }
      main { max-width: 980px; margin: 0 auto; padding: 56px 20px; }
      h1 { font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif; font-weight: 600; margin: 0 0 10px; }
      p { max-width: 780px; font-size: 16px; line-height: 1.6; color:#333; }
      a { color: inherit; text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px; }
      .list { margin-top: 26px; max-width: 780px; border-top: 1px solid #e5e5e5; }
      .row { padding: 16px 0; border-bottom: 1px solid #e5e5e5; }
      .meta { font-size: 13px; color:#555; line-height:1.6; }
      .title { font-size: 18px; margin-top: 6px; }
    </style>
  </head>
  <body>
    <main>
      <h1>Divisions</h1>
      <p>Divisional organization reflects current archival practice and remains subject to revision.</p>
      <hr style="border:none;border-top:1px solid #e5e5e5;margin:26px 0;" />
      <Nav current="divisions" />

      <div class="list">
        {divisions.map((d) => (
          <div class="row">
            <div class="meta">Latest filing: {d.latest}</div>
            <div class="title">
              <a href={`/divisions/${d.slug}`}>{d.name}</a>
            </div>
          </div>
        ))}
      </div>
    </main>
  </body>
</html>