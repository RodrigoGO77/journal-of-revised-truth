---
import { getCollection } from "astro:content";
import Layout from "../layouts/JournalLayout.astro";

const memos = await getCollection("memos");

const divisionMap = {};

for (const m of memos) {
  const slug = m.data.division_slug;
  if (!slug) continue;

  if (!divisionMap[slug]) {
    divisionMap[slug] = {
      name: m.data.division,
      slug: m.data.division_slug,
      latest: m.data.published_at
    };
  } else if (m.data.published_at > divisionMap[slug].latest) {
    divisionMap[slug].latest = m.data.published_at;
  }
}

const divisions = Object.values(divisionMap).sort((a, b) =>
  a.name.localeCompare(b.name)
);
---

<Layout title="Divisions" current="divisions">

  <h1>Divisions</h1>

  <p style="max-width:780px; line-height:1.6; color:#333;">
    Divisional organization reflects current archival practice and remains subject to revision.
  </p>

  <div style="margin-top:26px; max-width:780px; border-top:1px solid #e5e5e5;">
    {divisions.map((d) => (
      <div style="padding:16px 0; border-bottom:1px solid #e5e5e5;">
        <div style="font-size:13px; color:#555; line-height:1.6;">
          Latest filing: {d.latest}
        </div>

        <div style="font-size:18px; margin-top:6px;">
          <a href={`/divisions/${d.slug}`}>{d.name}</a>
        </div>
      </div>
    ))}
  </div>

</Layout>