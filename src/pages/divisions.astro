---
import { getCollection } from "astro:content";

const memos = await getCollection("memos");

// Build a map: division -> memos
const byDivision = new Map<string, typeof memos>();
for (const m of memos) {
  const key = m.data.division;
  if (!byDivision.has(key)) byDivision.set(key, []);
  byDivision.get(key)!.push(m);
}

// Sort divisions alphabetically
const divisions = Array.from(byDivision.keys()).sort((a, b) => a.localeCompare(b));

// Sort memos inside each division by published_at desc
for (const [k, list] of byDivision.entries()) {
  list.sort((a, b) => (a.data.published_at < b.data.published_at ? 1 : -1));
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Divisions — The Journal of Revised Truth</title>
    <style>
      body { margin: 0; font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial; background:#fff; color:#111; }
      main { max-width: 980px; margin: 0 auto; padding: 56px 20px; }
      h1 { font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif; font-weight: 600; margin: 0 0 10px; }
      .sub { max-width: 780px; font-size: 16px; line-height: 1.6; color:#333; }
      a { color: inherit; text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px; }
      nav { margin-top: 18px; font-size: 14px; display:flex; gap:18px; flex-wrap: wrap; }
      .list { margin-top: 26px; max-width: 780px; border-top: 1px solid #e5e5e5; }
      .row { padding: 16px 0; border-bottom: 1px solid #e5e5e5; }
      .meta { font-size: 13px; color:#333; line-height:1.6; }
      .title { font-size: 18px; margin-top: 6px; }
    </style>
  </head>
  <body>
    <main>
      <h1>Divisions</h1>
      <div class="sub">
        Divisional organization reflects current archival practice and remains subject to revision.
      </div>

      <nav>
        <a href="/">Home</a>
        <a href="/archive">Archive</a>
        <a href="/mission">Mission</a>
        <a href="/about">About</a>
      </nav>

      <div class="list">
        {divisions.map((d) => {
          const latest = byDivision.get(d)![0];
          return (
            <div class="row">
              <div class="meta">Latest filing: {latest.data.published_at} · Memorandum {latest.data.memo_id}</div>
              <div class="title"><a href={`/divisions/${encodeURIComponent(d)}`}>{d}</a></div>
            </div>
          );
        })}
      </div>
    </main>
  </body>
</html>