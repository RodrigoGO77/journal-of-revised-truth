---
import Nav from "../components/Nav.astro";
import "../styles/journal.css";

const { title, current, showStamp = false } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />

    <title>{title} — The Journal of Revised Truths</title>

    <meta
      name="description"
      content="The Journal of Revised Truths compiles memoranda concerning the evolution of human understanding across eras, institutions, and domains."
    />
    <meta
      name="keywords"
      content="satire, historical satire, bureaucratic satire, cold war satire, government memos, fictional archives"
    />
    <meta name="author" content="Journal of Revised Truths Editorial Office" />

    <meta property="og:title" content="The Journal of Revised Truths" />
    <meta
      property="og:description"
      content="Institutional memoranda documenting revised understandings of historical events."
    />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="The Journal of Revised Truths" />
    <meta
      name="twitter:description"
      content="An archival collection of bureaucratic memoranda documenting revised truths."
    />
  </head>

  <body>
    <main>
      <div class="masthead">
        <div class="site-title">
          The Journal of Revised Truths
        </div>

        <div class="motto">
          Humanity remains operational.
        </div>
      </div>

      <Nav current={current} />

      <hr />

      <div class="document-container">
        {showStamp && (
          <div class="declassified-stamp">
            DECLASSIFIED
          </div>
        )}

        <article>
          <slot />
        </article>
      </div>
    </main>
  </body>
</html>