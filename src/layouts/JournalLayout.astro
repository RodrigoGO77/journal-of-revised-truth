---
import Nav from "../components/Nav.astro";

const { title, current } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title} — The Journal of Revised Truth</title>

    <style>

      body{
        margin:0;
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial;
        background:#fff;
        color:#111;
      }

      main{
        max-width:980px;
        margin:auto;
        padding:48px 20px 60px 20px;
      }

      .masthead{
        margin-bottom:34px;
      }

      .journal-title{
        font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
        font-size:20px;
        letter-spacing:.08em;
        text-transform:uppercase;
        font-weight:600;
      }

      .motto{
        font-size:14px;
        color:#555;
        margin-top:6px;
      }

      h1{
        font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
        font-weight:600;
        margin:0 0 12px;
      }

      a{
        color:inherit;
        text-decoration: underline;
        text-underline-offset:3px;
      }

      hr{
        border:none;
        border-top:1px solid #e5e5e5;
        margin:26px 0;
      }

    </style>

  </head>

  <body>

    <main>

      <div class="masthead">

        <div class="journal-title">
          The Journal of Revised Truth
        </div>

        <div class="motto">
          Humanity remains operational.
        </div>

      </div>

      <Nav current={current} />

      <hr />

      <slot />

    </main>

  </body>
</html>